# Runtime service
APP_CONFIG_PATH=backend/config/app.toml
HOST=127.0.0.1
PORT=8099
DEBUG=false

# CORS
CORS_ORIGINS=["http://localhost:5199","http://127.0.0.1:5199","http://localhost:5175","http://127.0.0.1:5175"]

# Local fallback data
MOCK_DATA_PATH=backend/data/mock
LOCAL_KB_PATH=data/knowledge-base

# 投研基准日（可选，YYYY-MM-DD）。留空则使用服务器当前日期（Asia/Shanghai）
REFERENCE_DATE=

# =============================================================================
# 真实密钥只写入 backend/.env（本文件为模板，字段留空，勿提交密钥）
# =============================================================================

# --- 硅基流动 LLM / 意图识别（意图识别 + 质检，建议独立 Key）---
LLM_INTENT_API_KEY=
LLM_INTENT_BASE_URL=https://api.siliconflow.cn/v1
LLM_INTENT_MODEL=deepseek-ai/DeepSeek-V3

# --- 硅基流动 LLM / 主输出（回答生成，建议独立 Key）---
LLM_API_KEY=
LLM_BASE_URL=https://api.siliconflow.cn/v1
LLM_MODEL=Qwen/Qwen3.5-27B

# --- 硅基流动 Embedding（知识库向量化，T-010 起使用）---
EMBEDDING_API_KEY=
EMBEDDING_BASE_URL=https://api.siliconflow.cn/v1
EMBEDDING_MODEL=BAAI/bge-large-zh-v1.5
EMBEDDING_DIM=1024
EMBEDDING_TIMEOUT=180

# --- 硅基流动 Rerank（检索重排，T-011 起使用）---
RERANK_API_KEY=
RERANK_BASE_URL=https://api.siliconflow.cn/v1
RERANK_MODEL=BAAI/bge-reranker-v2-m3

# 问数行情：market_ranking_lookup 走东财 push2（third_party/a-stock-data 适配）；失败自动降级 demo
# 热点信号：hotspot_signal_lookup 走同花顺题材标签；失败降级知识库主题摘要（高置信、时效滞后）

# LangGraph 本地编排开关（T-012 Chat 仅走 LangGraph 编排）
# 设为 local 启用；留空或其他值时 POST /api/chat/query 返回 503
LANGGRAPH_ENV=local
